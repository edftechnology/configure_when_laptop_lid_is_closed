#!/usr/bin/env bash

set -euo pipefail

HOME_DIR="${HOME:?HOME is required}"
CACHE_BASE="${XDG_CACHE_HOME:-$HOME_DIR/.cache}"
STATE_ROOT="$CACHE_BASE/git-repo-watch"
KNOWN_DIR="$STATE_ROOT/known"
QUEUE_DIR="$STATE_ROOT/queue"
LOCK_DIR="$STATE_ROOT/locks"
STATE_DIR="$STATE_ROOT/state"

STALE_SECONDS="${GIT_REPO_WATCH_STALE_SECONDS:-900}"
LOOP_SECONDS="${GIT_REPO_WATCH_LOOP_SECONDS:-5}"
SCAN_SECONDS="${GIT_REPO_WATCH_SCAN_SECONDS:-60}"
MAX_PERIODIC_REFRESH="${GIT_REPO_WATCH_MAX_PERIODIC_REFRESH:-4}"

ensure_dirs() {
  mkdir -p "$KNOWN_DIR" "$QUEUE_DIR" "$LOCK_DIR" "$STATE_DIR"
}

repo_root() {
  git -C "${1:-$PWD}" rev-parse --show-toplevel 2>/dev/null
}

repo_key() {
  printf '%s' "$1" | git hash-object --stdin
}

repo_label() {
  basename "$1"
}

state_file_for_key() {
  printf '%s/%s.state\n' "$STATE_DIR" "$1"
}

notified_file_for_key() {
  printf '%s/%s.notified\n' "$STATE_DIR" "$1"
}

write_state_file() {
  local key="$1"
  local repo="$2"
  local branch="$3"
  local upstream="$4"
  local state="$5"
  local ahead="$6"
  local behind="$7"
  local last_checked="$8"
  local message="$9"
  local suggested_cmd="${10}"
  local signature="${11}"
  local tmp_file

  tmp_file="$(mktemp "$STATE_DIR/$key.XXXXXX")"
  {
    printf 'repo=%q\n' "$repo"
    printf 'branch=%q\n' "$branch"
    printf 'upstream=%q\n' "$upstream"
    printf 'state=%q\n' "$state"
    printf 'ahead=%q\n' "$ahead"
    printf 'behind=%q\n' "$behind"
    printf 'last_checked=%q\n' "$last_checked"
    printf 'message=%q\n' "$message"
    printf 'suggested_cmd=%q\n' "$suggested_cmd"
    printf 'signature=%q\n' "$signature"
  } > "$tmp_file"
  mv "$tmp_file" "$(state_file_for_key "$key")"
}

load_state_file() {
  local state_file="$1"

  repo=""
  branch=""
  upstream=""
  state="unknown"
  ahead="0"
  behind="0"
  last_checked="0"
  message=""
  suggested_cmd=""
  signature=""

  # The file is generated by this script with shell-escaped values.
  # shellcheck disable=SC1090
  source "$state_file"
}

mark_repo_known() {
  local repo="$1"
  local key="$2"

  printf '%s\n' "$repo" > "$KNOWN_DIR/$key.path"
}

queue_repo() {
  local repo
  local key

  repo="$(repo_root "${1:-$PWD}")" || return 1
  ensure_dirs
  key="$(repo_key "$repo")"
  mark_repo_known "$repo" "$key"
  printf '%s\n' "$repo" > "$QUEUE_DIR/$key.req"
}

maybe_notify() {
  local key="$1"
  local repo="$2"
  local branch="$3"
  local upstream="$4"
  local state="$5"
  local ahead="$6"
  local behind="$7"
  local signature="$8"
  local notified_file
  local last_notified=""
  local body=""

  if ! command -v notify-send >/dev/null 2>&1; then
    return 0
  fi

  notified_file="$(notified_file_for_key "$key")"
  if [[ -f "$notified_file" ]]; then
    last_notified="$(<"$notified_file")"
  fi
  if [[ "$signature" == "$last_notified" ]]; then
    return 0
  fi

  case "$state" in
    behind)
      body="$repo
$branch is $behind commit(s) behind $upstream."
      ;;
    diverged)
      body="$repo
$branch diverged from $upstream: $ahead ahead and $behind behind."
      ;;
    *)
      return 0
      ;;
  esac

  if notify-send -a git-repo-watch "Git Update Available" "$body" >/dev/null 2>&1; then
    printf '%s\n' "$signature" > "$notified_file"
  fi
}

record_repo_state() {
  local repo="$1"
  local branch="$2"
  local upstream="$3"
  local state="$4"
  local ahead="$5"
  local behind="$6"
  local message="$7"
  local suggested_cmd="$8"
  local signature="$9"
  local key
  local now_epoch

  ensure_dirs
  key="$(repo_key "$repo")"
  now_epoch="$(date +%s)"
  mark_repo_known "$repo" "$key"
  write_state_file \
    "$key" \
    "$repo" \
    "$branch" \
    "$upstream" \
    "$state" \
    "$ahead" \
    "$behind" \
    "$now_epoch" \
    "$message" \
    "$suggested_cmd" \
    "$signature"
  maybe_notify "$key" "$repo" "$branch" "$upstream" "$state" "$ahead" "$behind" "$signature"
}

refresh_repo() {
  local repo="$1"
  local key
  local lock_file
  local branch
  local upstream=""
  local ahead="0"
  local behind="0"
  local state
  local message=""
  local suggested_cmd=""
  local signature=""

  repo="$(repo_root "$repo")" || return 1
  ensure_dirs
  key="$(repo_key "$repo")"
  lock_file="$LOCK_DIR/$key.lock"
  mark_repo_known "$repo" "$key"

  exec 9>"$lock_file"
  if ! flock -n 9; then
    return 0
  fi

  branch="$(git -C "$repo" symbolic-ref --quiet --short HEAD 2>/dev/null || true)"
  if [[ -z "$branch" ]]; then
    branch="detached@$(git -C "$repo" rev-parse --short HEAD 2>/dev/null || printf 'unknown')"
  fi

  if ! GIT_TERMINAL_PROMPT=0 git -C "$repo" fetch --all --prune --quiet >/dev/null 2>&1; then
    state="fetch_failed"
    message="[git-watch] $(repo_label "$repo")/$branch: background fetch failed."
    suggested_cmd="git fetch --all --prune"
    signature="$state|$branch"
    record_repo_state "$repo" "$branch" "$upstream" "$state" "$ahead" "$behind" "$message" "$suggested_cmd" "$signature"
    return 0
  fi

  upstream="$(git -C "$repo" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
  if [[ -z "$upstream" ]]; then
    state="no_upstream"
    signature="$state|$branch"
    record_repo_state "$repo" "$branch" "$upstream" "$state" "$ahead" "$behind" "$message" "$suggested_cmd" "$signature"
    return 0
  fi

  read -r ahead behind < <(git -C "$repo" rev-list --left-right --count HEAD..."$upstream")

  if (( behind > 0 && ahead == 0 )); then
    state="behind"
    message="[git-watch] $(repo_label "$repo")/$branch: $behind commit(s) behind $upstream. Run: git pull --ff-only"
    suggested_cmd="git pull --ff-only"
  elif (( behind > 0 && ahead > 0 )); then
    state="diverged"
    message="[git-watch] $(repo_label "$repo")/$branch diverged from $upstream: $ahead ahead, $behind behind. Review before merging."
    suggested_cmd="git pull --rebase"
  elif (( ahead > 0 )); then
    state="ahead"
  else
    state="up_to_date"
  fi

  signature="$state|$branch|$upstream|$ahead|$behind"
  record_repo_state "$repo" "$branch" "$upstream" "$state" "$ahead" "$behind" "$message" "$suggested_cmd" "$signature"
}

state_is_stale() {
  local key="$1"
  local now_epoch="$2"
  local state_file

  state_file="$(state_file_for_key "$key")"
  if [[ ! -f "$state_file" ]]; then
    return 0
  fi

  load_state_file "$state_file"
  (( now_epoch - last_checked >= STALE_SECONDS ))
}

remove_missing_repo_artifacts() {
  local key="$1"

  rm -f \
    "$KNOWN_DIR/$key.path" \
    "$QUEUE_DIR/$key.req" \
    "$(state_file_for_key "$key")" \
    "$(notified_file_for_key "$key")"
}

process_queue() {
  local request_file
  local repo
  local key

  shopt -s nullglob
  for request_file in "$QUEUE_DIR"/*.req; do
    key="$(basename "$request_file" .req)"
    repo="$(<"$request_file")"
    rm -f "$request_file"
    if [[ ! -d "$repo" ]]; then
      remove_missing_repo_artifacts "$key"
      continue
    fi
    refresh_repo "$repo" || true
  done
  shopt -u nullglob
}

refresh_stale_known_repos() {
  local now_epoch="$1"
  local path_file
  local repo
  local key
  local refreshed=0

  shopt -s nullglob
  for path_file in "$KNOWN_DIR"/*.path; do
    key="$(basename "$path_file" .path)"
    repo="$(<"$path_file")"
    if [[ ! -d "$repo" ]]; then
      remove_missing_repo_artifacts "$key"
      continue
    fi
    if state_is_stale "$key" "$now_epoch"; then
      refresh_repo "$repo" || true
      refreshed=$((refreshed + 1))
      if (( refreshed >= MAX_PERIODIC_REFRESH )); then
        break
      fi
    fi
  done
  shopt -u nullglob
}

daemon_loop() {
  local last_scan=0
  local now_epoch

  ensure_dirs
  while true; do
    process_queue
    now_epoch="$(date +%s)"
    if (( now_epoch - last_scan >= SCAN_SECONDS )); then
      refresh_stale_known_repos "$now_epoch"
      last_scan="$now_epoch"
    fi
    sleep "$LOOP_SECONDS"
  done
}

print_status_line() {
  local repo="$1"
  local key
  local state_file
  local now_epoch

  repo="$(repo_root "$repo")" || return 1
  key="$(repo_key "$repo")"
  state_file="$(state_file_for_key "$key")"

  if [[ ! -f "$state_file" ]]; then
    printf '[git-watch] %s: checking remote in background...\n' "$(repo_label "$repo")"
    return 0
  fi

  load_state_file "$state_file"
  now_epoch="$(date +%s)"
  if (( now_epoch - last_checked >= STALE_SECONDS )); then
    queue_repo "$repo" >/dev/null 2>&1 || true
  fi

  case "$state" in
    behind|diverged|fetch_failed)
      printf '%s\n' "$message"
      ;;
    unknown)
      printf '[git-watch] %s: checking remote in background...\n' "$(repo_label "$repo")"
      ;;
  esac
}

list_known_repos() {
  local path_file

  ensure_dirs
  shopt -s nullglob
  for path_file in "$KNOWN_DIR"/*.path; do
    cat "$path_file"
  done
  shopt -u nullglob
}

usage() {
  cat <<'EOF'
Usage:
  git-repo-watchctl daemon
  git-repo-watchctl enqueue [path]
  git-repo-watchctl refresh [path]
  git-repo-watchctl status-line [path]
  git-repo-watchctl repo-root [path]
  git-repo-watchctl list
EOF
}

main() {
  local command="${1:-}"

  case "$command" in
    daemon)
      daemon_loop
      ;;
    enqueue)
      queue_repo "${2:-$PWD}"
      ;;
    refresh)
      refresh_repo "${2:-$PWD}"
      ;;
    status-line)
      print_status_line "${2:-$PWD}"
      ;;
    repo-root)
      repo_root "${2:-$PWD}"
      ;;
    list)
      list_known_repos
      ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"
